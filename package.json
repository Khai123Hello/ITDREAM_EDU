{
    "name": "nail-fe",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "postinstall": "cd .. && husky install source/.husky",
        "start": "env-cmd -f ./env/.dev craco start",
        "prebuild:dev": "rm -rf build",
        "build:dev": "env-cmd -f ./env/.dev craco build",
        "build:beta": "env-cmd -f ./env/.beta craco build",
        "prebuild:prod": "rm -rf build",
        "build:production": "env-cmd -f ./env/.production craco build",
        "prebuild:staging": "rm -rf build",
        "build:staging": "env-cmd -f ./env/.staging craco build",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "lint": "eslint \"src/**/*.js\" --fix",
        "format": "prettier --write \"src/**/*.js\"",
        "i18n": "extract-react-intl-messages -l=en -d en -o src/locales --flat \"src/**/*.js\""
    },
    "dependencies": {
        "@commitlint/cli": "^17.0.0",
        "@commitlint/config-conventional": "^17.3.0",
        "@craco/craco": "^7.0.0",
        "@jackwilsdon/craco-use-babelrc": "^1.0.0",
        "@markdoc/markdoc": "^0.5.7",
        "@radix-ui/react-collapsible": "^1.1.1",
        "@radix-ui/react-dialog": "^1.1.2",
        "@radix-ui/react-dropdown-menu": "^2.1.2",
        "@radix-ui/react-navigation-menu": "^1.2.1",
        "@radix-ui/react-tooltip": "^1.1.4",
        "@react-oauth/google": "^0.13.5",
        "@reduxjs/toolkit": "^1.9.3",
        "@smastrom/react-rating": "^1.5.0",
        "@tanstack/react-query": "^5.59.15",
        "@tanstack/react-table": "^8.20.5",
        "@testing-library/jest-dom": "^5.16.4",
        "@testing-library/react": "^13.4.0",
        "@testing-library/user-event": "^14.2.0",
        "antd-img-crop": "^4.5.2",
        "axios": "^1.2.1",
        "babel-plugin-react-intl-auto": "^3.3.0",
        "body-scroll-lock": "^4.0.0-beta.0",
        "buffer": "^6.0.3",
        "classnames": "^2.3.2",
        "dayjs": "^1.11.7",
        "embla-carousel-autoplay": "^8.3.0",
        "embla-carousel-react": "^8.3.0",
        "env-cmd": "^10.1.0",
        "eslint-plugin-prettier": "^4.2.1",
        "extract-react-intl-messages": "^4.1.1",
        "husky": "^8.0.2",
        "immer": "^9.0.16",
        "itz-react-library": "^1.3.2",
        "jwt-decode": "^4.0.0",
        "lint-staged": "^13.1.0",
        "lodash": "^4.17.21",
        "query-string": "^8.0.3",
        "rc-drawer": "^7.2.0",
        "rc-field-form": "^2.4.0",
        "rc-picker": "^3.14.7",
        "rc-select": "^14.16.4",
        "rc-tooltip": "^5.2.2",
        "rc-upload": "^4.8.1",
        "react": "^18.3.1",
        "react-datepicker": "^4.8.0",
        "react-device-detect": "^2.2.3",
        "react-dom": "^18.3.1",
        "react-dropzone": "^14.3.5",
        "react-icons": "^5.3.0",
        "react-infinite-scroll-component": "^6.1.0",
        "react-intl": "^6.0.3",
        "react-loading-spin": "^2.1.9",
        "react-modern-drawer": "^1.4.0",
        "react-otp-input": "^3.1.1",
        "react-player": "^2.11.0",
        "react-quill": "^2.0.0",
        "react-redux": "^8.0.5",
        "react-router-dom": "^6.5.0",
        "react-scripts": "5.0.1",
        "react-select": "^5.7.0",
        "react-swipeable-list": "^1.10.0",
        "react-toastify": "^9.1.1",
        "redux": "^4.2.0",
        "redux-saga": "^1.2.2",
        "reselect": "^4.1.7",
        "sass": "^1.57.1",
        "sonner": "^1.5.0",
        "swiper": "^11.1.15",
        "tinycolor2": "^1.6.0",
        "web-vitals": "^2.1.4",
        "yup": "^0.32.11"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "lint-staged": {
        "*.js": [
            "npm run lint",
            "git add ."
        ]
    },
    "devDependencies": {
        "cross-env": "^7.0.3",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "prettier-eslint": "^16.3.0",
        "react-intersection-observer": "^9.14.0"
    }
}
